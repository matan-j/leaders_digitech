VITE_SUPABASE_PROJECT_ID=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_URL=

# ─── Telegram daily report (set in Supabase Dashboard → Edge Function Secrets) ───
# These are NOT used by the Vite frontend. They're consumed by the
# `daily-telegram-report` Edge Function only. Listed here for documentation.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CEO_CHAT_ID=
CRON_SECRET=

# ─── Brevo email sender (set in Supabase Dashboard → Edge Function Secrets) ───
# Consumed by `crm-ghl` Edge Function. BREVO_SENDER_EMAIL is REQUIRED — the
# function throws on missing value. BREVO_SENDER_NAME defaults to 'Leaders Digitech'.
# BREVO_REPLY_TO_EMAIL is optional (used as the reply-to address on outbound mail).
BREVO_API_KEY=
BREVO_SENDER_EMAIL=
BREVO_SENDER_NAME=
BREVO_REPLY_TO_EMAIL=

# ─── Green API (WhatsApp) — set in Supabase Dashboard → Edge Function Secrets ───
GREEN_API_URL=
GREEN_API_INSTANCE_ID=
GREEN_API_TOKEN=
